GuptaCoverage <- function(d,t) {#
	fn <- function(u) (pnorm(u+d)-pnorm(u))^(t-1)*dnorm(u)#
	t*simpson(-10, 10, 1000, fn)#
}#
#
ptgr <- expand.grid(p=pgr, t=pgr)#
CPU <- matrix(NA, length(pgr), length(pgr))#
for (i in 1:nrow(ptgr)) CPU[ptgr$p[i],ptgr$t[i]] <- GuptaCoverage(dsol[ptgr$p[i]], ptgr$t[i])
ptgr <- expand.grid(p=pgr, t=pgr)#
CPU <- matrix(NA, length(pgr), length(pgr))#
#
for (i in 1:length(pgr)) {#
    for (j in 1:length(pgr)) {#
        CPU[i,j] <- GuptaCoverage(dsol[i], ptgr$t[j])       #
    }#
}
CPU
ind <- CPU>0.95
