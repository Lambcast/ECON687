alpha <- 0.05
simpson <- function(a,b,n,f) {#
	h <- (b-a)/n#
	x <- seq(a,b,length.out=n+1)#
	fx <- rep(0,n+1)#
	for (i in 1:(n+1)) fx[i] <- f(x[i])#
	coeff <- c(1,rep(c(4,2),(n-1)/2),4,1)#
	return(h/3*sum(coeff*fx))#
}#
#
bisect <- function(a, b, f, xtol, maxit=20) {		# bisection algorithm to find root of f in [a,b]#
	stopifnot(f(a)*f(b)<=0)#
#
	if (a<b) { xl <- a; xu <- b; } else { xl <- b; xu <- a; }#
	if (f(xl)<0) { incr <- TRUE; } else { incr <- FALSE; }#
	it <- 1#
	while((xu-xl > xtol) && it<maxit) {#
		fx <- f((xu+xl)/2)#
		if (fx==0) {#
			xl <- (xu+xl)/2#
			xu <- (xu+xl)/2#
		} else {#
			if (incr) {				#
				if (fx > 0) { xu <- (xu+xl)/2; } else { xl <- (xu+xl)/2; }#
			} else {#
				if (fx > 0) { xl <- (xu+xl)/2; } else { xu <- (xu+xl)/2; }#
			}#
		}#
		it <- it + 1#
	}#
	x <- (xu+xl)/2#
	return(x)#
}
