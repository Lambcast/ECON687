library(MASS)#
    library(doMC)#
    library(abind)#
    library(xtable)#
    library(mvtnorm)#
    library("lattice")#
    library("latticeExtra")
# -----------------------------------------------------------------------------------------------------------------#
# methods based on CS for differences of means#
# -----------------------------------------------------------------------------------------------------------------#
    # ------------------- CS for differences of means#
    ##
    # INPUT:#
    ##
    # dat:      contain the data: either a matrix in which each column corresponds to a population or a vector in which case each entry is taken to be#
    #           the sample mean of a population#
    # sigmahat: set to NA in the case when dat is a matrix, otherwise should be the vector of estimated standard deviations of the populations' sample #
    #           means in dat#
    # alpha:    desired nominal coverage of the resulting confidence sets will be 1-alpha#
    # R:        number of bootstrap replications#
    # type:     type of CS ("symmetric", "two-sided", "upper", "lower")#
    # stepdown: can take three values: "single", "basic", "modified"#
    # indices:  indicates the individuals i for which joint coverage is desired. For example, if indices=1, then#
    #           the resulting CS covers jointly all differences#
    ##
    #               mu_j-mu_i for i=1,2 and all j \neq i#
    ##
    #           NA means joint coverage across all i and all j \neq i.#
    # bootstrap: type of bootstrap ("parametric" or "nonparametric"); nonparametric bootstrap is possible only if dat contains individual-level data#
    #           for each subpopulation (i.e. dat is a matrix)#
    ##
    # OUTPUT:#
    ##
    # L:        lower bounds of CS; matrix with number of columns equal to number of subpopulations and number of rows equal to the length of indices#
    # U:        upper bounds of CS; matrix with number of columns equal to number of subpopulations and number of rows equal to the length of indices#
    # I:        matrix indicating which dimensions of the CS include zero (TRUE) and which do not (FALSE)#
    ##
    CSDiffMeans <- function(dat, sigmahat=NA, alpha=0.05, R=1000, CStype="symmetric", stepdown="single", indices=NA, bootstrap="parametric", seed=NA) {#
        # check arguments#
        bootstrap <- match.arg(bootstrap, c("parametric", "nonparametric"))#
        CStype <- match.arg(CStype, c("symmetric", "two-sided", "upper", "lower"))#
        stepdown <- match.arg(stepdown, c("single", "basic", "modified"))#
#
        # does dat contain individual data or population-specific means?#
        if (is.matrix(dat)) {#
            thetahat <- colMeans(dat)#
            sigmahat <- sqrt(diag(cov(dat))/nrow(dat))#
        } else {#
            stopifnot(!is.na(sigmahat))#
            stopifnot(bootstrap=="parametric")#
            thetahat <- dat#
        }#
#
        # initializations#
        p <- length(thetahat)#
        if (any(is.na(indices))) indices <- 1:p#
        thetadiff <- outer(thetahat, thetahat, '-')#
        sigmadiff <- sqrt(outer(sigmahat^2, sigmahat^2, '+'))#
        anyrejections <- TRUE#
        ChatL <- matrix(0,p,p); ChatU <- ChatL#
        maxabs <- function(x) max(abs(x))#
        mmax <- function(x) max(-x)#
        # which differences?        #
        I0 <- matrix(TRUE, p, p); I0[-indices,] <- FALSE; #
        if (stepdown=="modified" & CStype=="symmetric") {#
            CStype <- "lower"#
            I0[,indices] <- TRUE#
        } #
        diag(I0) <- FALSE; I1 <- I0; Istar <- I0        #
#
        # parametric bootstrap#
        if (bootstrap=="parametric") {#
            diffFn <- function(Z, I, fn) {#
                Zdiff <- outer(Z, Z, '-')#
                fn(Zdiff[I]/sigmadiff[I])#
            }#
#
            # beta-quantiles from Ln and Un#
            LLowerInv <- function(I, beta) quantile(replicate(R, diffFn(sigmahat*rnorm(p), I, max)), probs=beta)#
            LUpperInv <- function(I, beta) quantile(replicate(R, diffFn(sigmahat*rnorm(p), I, mmax)), probs=beta)#
            LSymmInv <- function(I, beta) quantile(replicate(R, diffFn(sigmahat*rnorm(p), I, maxabs)), probs=beta)#
        }#
#
        # nonparametric bootstrap#
        if (bootstrap=="nonparametric") {#
            diffFnb <- function(zind, I, fn) {#
                Z <- dat[zind,]#
                thetahatb <- colMeans(Z)#
                sigmahatb <- sqrt(diag(cov(Z))/nrow(Z))#
                thetadiffb <- outer(thetahatb, thetahatb, '-')#
                sigmadiffb <- sqrt(outer(sigmahatb^2, sigmahatb^2, '+'))#
                fn((thetadiffb[I]-thetadiff[I])/sigmadiffb[I])#
            }#
#
            # beta-quantiles from Ln and Un#
            LLowerInv <- function(I, beta) quantile(replicate(R, diffFnb(sample.int(nrow(dat), replace=TRUE), I, max)), probs=beta)#
            LUpperInv <- function(I, beta) quantile(replicate(R, diffFnb(sample.int(nrow(dat), replace=TRUE), I, mmax)), probs=beta)#
            LSymmInv <- function(I, beta) quantile(replicate(R, diffFnb(sample.int(nrow(dat), replace=TRUE), I, maxabs)), probs=beta)#
        }#
        # compute CS#
        if (!is.na(seed)) set.seed(seed)#
        while (anyrejections) {#
#
            # compute upper and lower confidence bounds#
            if (CStype=="lower") {#
                ChatL[I1] <- thetadiff[I1] - sigmadiff[I1]*LLowerInv(I1, 1-alpha)#
                ChatU <- matrix(Inf, p, p)  #
            }#
            if (CStype=="upper") {#
                ChatL <- matrix(-Inf, p, p)#
                ChatU[I1] <- thetadiff[I1] + sigmadiff[I1]*LUpperInv(I1, 1-alpha)#
            }#
            if (CStype=="two-sided") {#
                ChatL[I1] <- thetadiff[I1] - sigmadiff[I1]*LLowerInv(I1, 1-alpha/2)#
                ChatU[I1] <- thetadiff[I1] + sigmadiff[I1]*LUpperInv(I1, 1-alpha/2)#
            }#
            if (CStype=="symmetric") {#
                z <- LSymmInv(I1, 1-alpha)#
                ChatL[I1] <- thetadiff[I1] - sigmadiff[I1]*z#
                ChatU[I1] <- thetadiff[I1] + sigmadiff[I1]*z#
            }           #
#
            # remove indices for which interval does not contain 0#
            I1[ChatU < 0 | ChatL > 0] <- FALSE#
            if (stepdown=="basic") I1[indices,indices] <- I1[indices,indices] & t(I1[indices,indices])#
#
            # stepdown improvements?#
            if (stepdown=="basic" | stepdown=="modified") {#
                # any new rejections?#
                if (sum(I1)==sum(I0) | sum(I1)==0) {#
                    anyrejections <- FALSE#
                } else {#
                    I0 <- I1#
                }#
            } else anyrejections <- FALSE#
        }#
#
        ChatL[!Istar] <- NA; colnames(ChatL) <- 1:p; rownames(ChatL) <- 1:p#
        ChatU[!Istar] <- NA; colnames(ChatU) <- 1:p; rownames(ChatU) <- 1:p#
        # I1[!Istar] <- NA; colnames(I1) <- 1:p; rownames(I1) <- 1:p#
#
        return(list(L=ChatL,U=ChatU))#
    }#
    # ------------------- CS for ranks#
    CSRanks.DiffMeans <- function(dat, sigmahat=NA, indices=1, CStype="symmetric", stepdown="single", ...) {#
#
        # joint CS for difference in means#
        if (CStype=="lower" | CStype=="upper") {#
            if (CStype=="upper") CSDifftype <- "lower"#
            if (CStype=="lower") CSDifftype <- "upper"  #
        } else {#
            CSDifftype <- CStype#
        }#
#
        # does dat contain individual data or population-specific means?#
        if (is.matrix(dat)) p <- ncol(dat) else p <- length(dat)#
        if (any(is.na(indices))) indices <- 1:p#
        res <- CSDiffMeans(dat, sigmahat, indices=indices, CStype=CSDifftype, stepdown=stepdown, ...)#
        L <- res$L; U <- res$U#
#
        # compute Nminus and Nplus#
        if (stepdown=="modified" & CStype=="symmetric") {#
            if (length(indices)==1 & all(!is.na(indices))) {#
                Nplus <- sum(L[indices,]>0, na.rm=TRUE)#
                Nminus <- sum(L[,indices]>0, na.rm=TRUE)#
            } else {#
                Nplus <- rowSums(L[indices,]>0, na.rm=TRUE)#
                Nminus <- colSums(L[,indices]>0, na.rm=TRUE)#
            }#
        } else {#
            if (length(indices)==1 & all(!is.na(indices))) {#
                Nplus <- sum(L[indices,]>0, na.rm=TRUE)#
                Nminus <- sum(U[indices,]<0, na.rm=TRUE)#
            } else {#
                Nplus <- rowSums(L[indices,]>0, na.rm=TRUE)#
                Nminus <- rowSums(U[indices,]<0, na.rm=TRUE)#
            }   #
        }#
#
        # return lower and upper confidence bounds for the ranks#
        return(list(L=(Nminus+1),U=(p-Nplus)))#
    }#
    # ------------------- CS for tau-best based on CIs for difference in means#
    CSTauBest.DiffMeans <- function(dat, sigmahat=NA, tau=2, stepdown="single", ...) {#
        # return indices whose lower bound on the rank is <= tau#
        L <- CSRanks.DiffMeans(dat, sigmahat, CStype="lower", indices=NA, stepdown=stepdown, ...)$L#
        return(L<=tau)#
    }#
    # ------------------- CS for tau-worst based on CIs for difference in means#
    CSTauWorst.DiffMeans <- function(dat, sigmahat=NA, tau=2, stepdown="single", ...) {#
        # return indices whose lower bound on the rank is >= p-tau+1#
        U <- CSRanks.DiffMeans(dat, sigmahat, CStype="upper", indices=NA, stepdown=stepdown, ...)$U#
        p <- length(U)#
        return(U>=p-tau+1)#
    }#
# -----------------------------------------------------------------------------------------------------------------#
# methods based on CS for means#
# -----------------------------------------------------------------------------------------------------------------#
    # ------------------- CS for means#
    CSMeans <- function(dat, sigmahat=NA, alpha=0.05, R=1000, CStype="symmetric", bootstrap="parametric") {#
#
        bootstrap <- match.arg(bootstrap, c("parametric", "nonparametric", "normal"))#
#
        # does dat contain individual data or population-specific means?#
        if (is.matrix(dat)) {#
            thetahat <- colMeans(dat)#
            sigmahat <- sqrt(diag(cov(dat))/nrow(dat))#
        } else {#
            stopifnot(!any(is.na(sigmahat)))#
            stopifnot(bootstrap=="parametric" | bootstrap=="normal")#
            thetahat <- dat#
        }#
        # initializations#
        CStype <- match.arg(CStype, c("two-sided", "upper", "lower", "symmetric"))#
        p <- length(thetahat)#
        maxabs <- function(x) max(abs(x))#
        mmax <- function(x) max(-x)#
#
        # parametric bootstrap#
        if (bootstrap=="parametric") {#
            # beta-quantiles from Ln and Un#
            LLowerInv <- function(beta) quantile(replicate(R, max(rnorm(p))), probs=beta)#
            LUpperInv <- function(beta) quantile(replicate(R, mmax(rnorm(p))), probs=beta)#
            LSymmInv <- function(beta) quantile(replicate(R, maxabs(rnorm(p))), probs=beta)#
        }#
#
        # nonparametric bootstrap#
        if (bootstrap=="nonparametric") {#
            Fnb <- function(zind, fn) {#
                Z <- dat[zind,]#
                thetahatb <- colMeans(Z)#
                sigmahatb <- sqrt(diag(cov(Z))/nrow(Z))#
                fn((thetahatb-thetahat)/sigmahatb)#
            }#
#
            # beta-quantiles from Ln and Un#
            LLowerInv <- function(beta) quantile(replicate(R, Fnb(sample.int(nrow(dat), replace=TRUE), max)), probs=beta)#
            LUpperInv <- function(beta) quantile(replicate(R, Fnb(sample.int(nrow(dat), replace=TRUE), mmax)), probs=beta)#
            LSymmInv <- function(beta) quantile(replicate(R, Fnb(sample.int(nrow(dat), replace=TRUE), maxabs)), probs=beta)#
        }#
#
        # asymptotic normality#
        if (bootstrap=="normal") {#
#
            # beta-quantiles from Ln and Un#
            LLowerInv <- function(beta) qnorm(beta^(1/p))#
            LUpperInv <- function(beta) qnorm(beta^(1/p))#
            LSymmInv <- function(beta) qnorm((1+beta^(1/p))/2)#
        }#
        # compute upper and lower confidence bounds#
        if (CStype=="lower") {#
            ChatL <- thetahat - sigmahat*LLowerInv(1-alpha)#
            ChatU <- rep(Inf, p)    #
        }#
        if (CStype=="upper") {#
            ChatL <- rep(-Inf, p)#
            ChatU <- thetahat + sigmahat*LUpperInv(1-alpha)#
        }#
        if (CStype=="two-sided") {#
            ChatL <- thetahat - sigmahat*LLowerInv(1-alpha/2)#
            ChatU <- thetahat + sigmahat*LUpperInv(1-alpha/2)#
        }       #
        if (CStype=="symmetric") {#
            ChatL <- thetahat - sigmahat*LSymmInv(1-alpha)#
            ChatU <- thetahat + sigmahat*LSymmInv(1-alpha)#
        }   #
#
        return(list(L=ChatL,U=ChatU))#
    }#
    # ------------------- CS for ranks#
    CSRanks.Means <- function(dat, sigmahat=NA, indices=NA, ...) {#
#
        if (is.matrix(dat)) p <- ncol(dat) else p <- length(dat)#
        if (any(is.na(indices))) indices <- 1:p#
#
        # joint CS for means#
        res <- CSMeans(dat, sigmahat, CStype="symmetric", ...)#
        L <- res$L; U <- res$U#
#
        # compute upper and lower confidence bounds for the ranks#
        U.r <- rep(NA,p); L.r <- rep(NA,p)#
        for (i in indices) {#
            LambdaL <- sum(U[-i]<L[i])#
            LambdaR <- sum(U[i]<L[-i])#
            U.r[i] <- p - LambdaL#
            L.r[i] <- LambdaR+1#
        }#
#
        return(list(L=L.r[indices],U=U.r[indices]))#
    }#
    # ------------------- CS for tau-best#
    CSTauBest.Means <- function(dat, sigmahat=NA, tau=2, ...) {#
        # return indices whose lower bound on the rank is <= tau#
        L <- CSRanks.Means(dat, sigmahat, indices=NA, ...)$L#
        return(L<=tau)#
    }#
#
    # ------------------- CS for tau-worst#
    CSTauWorst.Means <- function(dat, sigmahat=NA, tau=2, ...) {#
        # return indices whose lower bound on the rank is >= p-tau+1#
        U <- CSRanks.Means(dat, sigmahat, indices=NA, ...)$U#
        if (is.matrix(dat)) p <- ncol(dat) else p <- length(dat)#
        return(U>=p-tau+1)#
    }#
# -----------------------------------------------------------------------------------------------------------------#
# direct method for tau-best problem#
# -----------------------------------------------------------------------------------------------------------------#
    # ------------------- CS for tau-best based on test statistic T (implemented only for tau=2)#
    CSTauBest.T <- function(thetahat, sigmahat, tau=2, alpha=0.05, R=1000, studentized="SE", n=NA) {#
        stopifnot(tau==2)#
        stopifnot(!any(is.na(sigmahat)))#
#
        # initializations#
        reject <- TRUE#
        p <- length(thetahat)#
        S <- rep(TRUE,p)#
#
        # compute Tnjk#
        Tnjk <- computeTnjk(thetahat, sigmahat, studentized, n=n)#
#
        # compute the test statistic Tnj#
        Tnj <- apply(Tnjk, 2, min)#
#
        # draw bootstrap version of Tnjk#
        Tnjk.sim <- replicate(R, computeTnjk(sigmahat*rnorm(p), sigmahat, studentized, n=n))    #
#
        # repeatedly perform the test with smaller and smaller S until fail to reject#
        while (reject) {#
#
            # compute cval#
            Tk <- apply(Tnjk.sim[,S,], c(1,3), max)#
            cval <- max(apply(Tk, 1, quantile, prob=1-alpha))#
            # perform test#
            reject <- any(Tnj[S] > cval)#
            ind.newRejects <- which(Tnj > cval & S)#
#
            # remove all rejected individuals#
            if (reject) S[ind.newRejects] <- FALSE#
        }#
#
        return(S)#
    }#
#
    # compute the test statistic for the individual hypothesis H_i using a fixed k#
    ##
    #        T_{n,j,k} = max_{l!=k} [ thetahat_l - thetahat_j ] / s_{lj}#
    ##
    computeTnjk <- function(thetahat, sigmahat, studentized="SE", n=NA) {#
#
        stopifnot(!(is.na(n) & studentized=="n"))#
        # compute standardized difference of thetas#
        p <- length(thetahat)#
        tmat <- matrix(rep(thetahat,p), ncol=p)#
        smat <- matrix(rep(sigmahat^2,p), ncol=p)#
        thetadiff <- tmat - t(tmat)#
        thetadiff <- switch(studentized,#
            "SE" = thetadiff/sqrt(smat+t(smat)),#
            "n" = sqrt(n)*thetadiff)#
        # compute max over j!=k #
        Tnjk <- apply(thetadiff, 2, loomax)#
#
        return(Tnjk)#
    }#
    # compute leave-one-out max of a vector#
    loomax <- function(x) {#
        top2 <- sort(x, decreasing=TRUE)[1:2]#
        return(ifelse(x==top2[1], top2[2], top2[1]))#
    }#
    # ------------------- alternative CS for tau-best based on test statistic T (implemented only for tau=2)#
    CSTauBest.T.alt <- function(thetahat, sigmahat, tau=2, alpha=0.05, R=1000, studentized="SE", n=NA, epsilon=NA) {#
        stopifnot(tau==2)#
        stopifnot(!any(is.na(sigmahat)))#
#
        if (is.na(epsilon)) { #
            stopifnot(!is.na(n))#
            epsilon <- log(n)/sqrt(n)#
        }#
#
        # initializations#
        reject <- TRUE#
        p <- length(thetahat)#
        S <- rep(TRUE,p)#
#
        # compute Knhat#
        secondBest <- thetahat[order(thetahat, decreasing=TRUE)][2]#
        Knhat <- thetahat <= secondBest + epsilon#
#
        # compute the test statistic Tnj#
        smat <- matrix(rep(sigmahat^2,p), ncol=p)#
        computeTnj <- function(x) {#
            xmat <- matrix(rep(x,p), ncol=p)#
            xmatDiff <- xmat - t(xmat)#
            if (studentized=="SE") xmatDiff <- xmatDiff / sqrt(smat+t(smat))#
#
            return(apply(xmatDiff[Knhat,], 2, max)  )#
        }#
        Tnj <- computeTnj(thetahat)#
        # draw bootstrap version of Tnj#
        Tnj.sim <- replicate(R, computeTnj(sigmahat*rnorm(p)))  #
#
        # repeatedly perform the test with smaller and smaller S until fail to reject#
        while (reject) {#
#
            # compute cval#
            if (sum(S)==1) Tk <- Tnj.sim[S,] else Tk <- apply(Tnj.sim[S,], 2, max)#
            cval <- quantile(Tk, prob=1-alpha)#
            # perform test#
            reject <- any(Tnj[S] > cval)#
            ind.newRejects <- which(Tnj > cval & S)#
#
            # remove all rejected individuals#
            if (reject) S[ind.newRejects] <- FALSE#
        }#
#
        return(S)#
    }#
    # ------------------- CS for tau-best based on test statistic T (parallel version, for any value of tau)#
    CSTauBest.T.parallel <- function(dat, sigmahat, tau=2, alpha=0.05, R=1000, blockSize=100, bootstrap="parametric", nCores=1) {#
        stopifnot(bootstrap=="parametric")#
#
        # does dat contain individual data or population-specific means?#
        if (is.matrix(dat)) {#
            thetahat <- colMeans(dat)#
            sigmahat <- sqrt(diag(cov(dat))/nrow(dat))#
        } else {#
            if (any(is.na(sigmahat))) stop("Need to provide sigmahat!")#
            stopifnot(bootstrap=="parametric")#
            thetahat <- dat#
        }#
#
        # initializations#
        reject <- TRUE#
        p <- length(thetahat)#
        I <- rep(TRUE, p)#
        registerDoMC(nCores)#
#
        # compute test statistics T_{n,j}#
        T_nj <- sort(thetahat, decreasing=TRUE)[tau] - thetahat#
#
        # set of subsets K#
        ncalK <- choose(p,p-tau+1)#
        nKBlocks <- ceiling(ncalK/blockSize)#
        indL <- ((1:nKBlocks)-1)*blockSize + 1#
        indU <- ifelse((1:nKBlocks)*blockSize <= ncalK, (1:nKBlocks)*blockSize, ncalK)#
#
        while (reject) {#
#
            # compute critical value#
            if (tau==1) {#
                computeT_nIK <- function(Z) return(max(Z)-min(Z[I]))#
                T_nIK.sim <- replicate(R, computeT_nIK(rnorm(p, 0, sigmahat)))#
                cval <- quantile(T_nIK.sim, prob=1-alpha)#
            } else {#
                res <- foreach(i=1:nKBlocks, .combine=c) %dopar% {#
                    computeT_nIK <- function(Z) return(apply(combn(Z, p-tau+1)[,indL[i]:indU[i]], 2, max) - min(Z[I]))#
                    T_nIK.sim <- replicate(R, computeT_nIK(rnorm(p, 0, sigmahat)))#
                    apply(T_nIK.sim, 1, quantile, prob=1-alpha)#
                }#
                cval <- max(res)    #
            }#
            # perform test#
            reject <- any(T_nj[I] > cval)#
#
            # remove all rejected hypotheses#
            if (reject) I <- T_nj <= cval#
        }#
#
        return(I)#
    }#
    # ------------------- CS for tau-worst based on test statistic T (parallel version, for any value of tau)#
    CSTauWorst.T.parallel <- function(dat, sigmahat, tau=2, alpha=0.05, R=1000, blockSize=100, bootstrap="parametric", nCores=1) {#
        stopifnot(bootstrap=="parametric")#
#
        # does dat contain individual data or population-specific means?#
        if (is.matrix(dat)) {#
            thetahat <- colMeans(dat)#
            sigmahat <- sqrt(diag(cov(dat))/nrow(dat))#
        } else {#
            if (any(is.na(sigmahat))) stop("Need to provide sigmahat!")#
            stopifnot(bootstrap=="parametric")#
            thetahat <- dat#
        }#
#
        # initializations#
        reject <- TRUE#
        p <- length(thetahat)#
        I <- rep(TRUE, p)#
        registerDoMC(nCores)#
#
        # compute test statistics T_{n,j}#
        T_nj <- thetahat - sort(thetahat, decreasing=TRUE)[p-tau+1]#
#
        # set of subsets K#
        ncalK <- choose(p,p-tau+1)#
        nKBlocks <- ceiling(ncalK/blockSize)#
        indL <- ((1:nKBlocks)-1)*blockSize + 1#
        indU <- ifelse((1:nKBlocks)*blockSize <= ncalK, (1:nKBlocks)*blockSize, ncalK)#
#
        while (reject) {#
#
            # compute critical value#
            if (tau==1) {#
                computeT_nIK <- function(Z) return(max(Z[I])-min(Z))#
                T_nIK.sim <- replicate(R, computeT_nIK(rnorm(p, 0, sigmahat)))#
                cval <- quantile(T_nIK.sim, prob=1-alpha)#
            } else {#
                res <- foreach(i=1:nKBlocks, .combine=c) %dopar% {#
                    computeT_nIK <- function(Z) return(max(Z[I]) - apply(combn(Z, p-tau+1)[,indL[i]:indU[i]], 2, min))#
                    T_nIK.sim <- replicate(R, computeT_nIK(rnorm(p, 0, sigmahat)))#
                    apply(T_nIK.sim, 1, quantile, prob=1-alpha)#
                }#
                cval <- max(res)    #
            }#
            # perform test#
            reject <- any(T_nj[I] > cval)#
#
            # remove all rejected hypotheses#
            if (reject) I <- T_nj <= cval#
        }#
#
        return(I)#
    }#
# compute rank#
my.rank <- function(x, best=TRUE) return(best*(colSums(outer(x,x,'>'))+1) + (1-best)*(colSums(outer(x,x,'<'))+1))#
# -----------------------------------------------------------------------------------------------------------------#
# other approaches#
# -----------------------------------------------------------------------------------------------------------------#
    # pick tau best among estimated means#
    tauBest.naive <- function(thetahat, tau=2) {#
        ranking <- order(thetahat, decreasing=TRUE)#
        taubest <- rep(FALSE, length(thetahat))#
        taubest[ranking[1:tau]] <- TRUE#
        return(taubest)#
    }
dgp <- function(nobs=200, p=3, delta1=1, delta2=2, tmax=0, topTwo=1:2) {#
#
        theta <- rep(NA, p)#
        k <- length(topTwo)#
        theta[topTwo[1]] <- tmax+delta1#
        theta[topTwo[-1]] <- tmax+delta1/delta2#
        if (p-k>0) theta[-topTwo] <- seq(tmax,0,length=(p-k))#
        if (tmax==0 & delta1==0) allequal <- TRUE else allequal <- FALSE#
#
        trueRanking.best <- my.rank(theta, best=TRUE)#
        trueRanking.worst <- my.rank(theta, best=FALSE)#
#
        return(list(dat=mvrnorm(nobs, theta, diag(rep(1,p))), theta=theta, allequal=allequal, trueRanking.best=trueRanking.best, trueRanking.worst=trueRanking.worst))#
    }
dgp(p=100,delta2=1,tmax=0.5,topTwo=1)
dgp(p=100,delta1=0,delta2=1,tmax=0.5,topTwo=1)$theta
dgp(p=100,delta1=0.3,delta2=1,tmax=0.5,topTwo=1)$theta
my.rank <- function(x, best=TRUE) return(best*(colSums(outer(x,x,'>'))+1) + (1-best)*(colSums(outer(x,x,'<'))+1))
x<-c(4,4,4,4,3,6)
my.rank(x)
my.rank(x, best=FALSE)
6-my.rank(x, best=FALSE)+1
